# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is git-ignored; never commit it.

aws_region   = "ap-southeast-2"
project_name = "diet-designer"
environment  = "prod"

# Database
db_name           = "diet_designer"
db_username       = "postgres"
db_instance_class = "db.t3.micro"

# ECS task sizing (256 CPU = 0.25 vCPU, 512 MB RAM)
api_cpu    = 256
api_memory = 512
web_cpu    = 256
web_memory = 512

api_desired_count = 1
web_desired_count = 1
